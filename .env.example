# Server
PORT=3000
NODE_ENV=development

# Vault
VAULT_PATH=./vault
EXPORT_PATH=./vault/exports

# Authentication (leave empty to disable auth in dev mode)
# API keys: comma-separated for multiple users
AUTH_API_KEYS=your-api-key-1,your-api-key-2
# Master key: required for backup/restore operations
AUTH_MASTER_KEY=your-master-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ChromaDB
CHROMA_HOST=http://localhost:8000
CHROMA_COLLECTION=second_brain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI Whisper (for voice-to-text)
OPENAI_API_KEY=your_openai_api_key_here

# Notion Integration
NOTION_API_KEY=your_notion_integration_token_here
NOTION_ROOT_PAGE_ID=your_root_page_id_here

# Google Drive
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Canva
CANVA_API_KEY=your_canva_api_key_here
CANVA_BRAND_KIT_ID=your_brand_kit_id_here

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id_here
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
CLOUDFLARE_R2_BUCKET_NAME=second-brain-exports
