    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "chromadb": "^3.3.3",
    "chromadb-default-embed": "^2.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.4",
    "morgan": "^1.10.1",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^4.2.1",
    "openai": "^6.29.0",
